[
  "begin",
  ["define", "()", "object/call-method"],
  ["define", ".", "object/get-path"],
  ["define", "[]", "array/make"],
  ["define", "=>", "func/callback"],
  ["define", "new", "object/new"],
  [
    "define",
    "message-box",
    [
      "new",
      [".", "OpenTUI", "ScrollBoxRenderable"],
      "renderer",
      {
        "stickyScroll": true,
        "stickyStart": "bottom",
        "width": "100%",
        "height": "100%",
        "border": true,
        "title": "Messages",
        "padding": 1,
        "gap": 4
      }
    ]
  ],
  [
    "define",
    "input-box",
    [
      [".", "OpenTUI", "Box"],
      {
        "border": true
      },
      [
        "define",
        "my-input",
        [
          [".", "OpenTUI", "Input"],
          {
            "placeholder": "Type your message to Lion Agent here...",
            "width": "full"
          }
        ]
      ]
    ]
  ],
  [
    "define",
    "renderable-events-enter",
    [".", "OpenTUI", "InputRenderableEvents.ENTER"]
  ],
  [
    "define",
    "file-read-tool",
    [
      "()",
      "AI",
      "tool",
      {
        "description": "Read a file",
        "inputSchema": [
          "()",
          "Zod",
          "object",
          {
            "path": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "Path string to the file to read. This is passed directly to the node.js fs.readFileSync function, so make sure it is formatted as expected."
            ]
          }
        ],
        "execute": [
          "=>",
          [
            "lambda",
            ["input", "options"],
            ["()", "fs", "readFileSync", [".", "input", "path"], "utf8"]
          ]
        ]
      }
    ]
  ],
  [
    "define",
    "on-user-submit",
    [
      "lambda",
      ["message"],
      [
        "begin",
        [
          "define",
          "user-message-text",
          [
            "()",
            "OpenTUI",
            "Box",
            {
              "border": true,
              "title": "User"
            },
            ["()", "OpenTUI", "Text", { "content": "message" }]
          ]
        ],
        ["()", "message-box", "add", "user-message-text"],
        [
          "define",
          "handle-response",
          [
            "=>",
            [
              "lambda",
              ["response"],
              [
                "begin",
                [
                  "()",
                  "fs",
                  "writeFileSync",
                  "agent-response-log.json",
                  [
                    "object/json-stringify",
                    [".", "response", "steps"],
                    null,
                    2
                  ],
                  "utf8"
                ],
                [
                  "()",
                  "message-box",
                  "add",
                  [
                    "()",
                    "OpenTUI",
                    "Box",
                    {
                      "border": true,
                      "title": "Assistant"
                    },
                    [
                      "()",
                      "OpenTUI",
                      "Text",
                      { "content": [".", "response", "toolResults.0.output"] }
                    ]
                  ]
                ]
              ]
            ]
          ]
        ],
        [
          "()",
          [
            "()",
            "AI",
            "generateText",
            {
              "model": "model",
              "prompt": "message",
              "tools": { "read-file": "file-read-tool" }
            }
          ],
          "then",
          "handle-response"
        ]
      ]
    ]
  ],
  ["()", "my-input", "on", "renderable-events-enter", ["=>", "on-user-submit"]],
  ["()", "OpenTUI", "Box", {}, ["[]", "input-box", "message-box"]]
]
