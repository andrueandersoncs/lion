[
  "begin",
  ["define", "()", "object/call-method"],
  ["define", ".", "object/get-path"],
  ["define", "[]", "array/make"],
  ["define", "=>", "func/callback"],
  ["define", "new", "object/new"],
  [
    "define",
    "message-box",
    [
      "new",
      [".", "OpenTUI", "ScrollBoxRenderable"],
      "renderer",
      {
        "stickyScroll": true,
        "stickyStart": "bottom",
        "width": "100%",
        "height": "100%",
        "border": true,
        "title": "Messages",
        "padding": 1,
        "gap": 4
      }
    ]
  ],
  [
    "define",
    "input-box",
    [
      [".", "OpenTUI", "Box"],
      {
        "border": true
      },
      [
        "define",
        "my-input",
        [
          [".", "OpenTUI", "Input"],
          {
            "placeholder": "Type your message to Lion Agent here...",
            "width": "full"
          }
        ]
      ]
    ]
  ],
  [
    "define",
    "renderable-events-enter",
    [".", "OpenTUI", "InputRenderableEvents.ENTER"]
  ],
  [
    "define",
    "LabeledText",
    [
      "lambda",
      ["label", "text"],
      [
        "()",
        "OpenTUI",
        "Box",
        {
          "border": true,
          "title": "label"
        },
        ["()", "OpenTUI", "Text", { "content": "text" }]
      ]
    ]
  ],
  [
    "define",
    "file-read-tool",
    [
      "()",
      "AI",
      "tool",
      {
        "description": "Read a file",
        "inputSchema": [
          "()",
          "Zod",
          "object",
          {
            "path": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "Path string to the file to read. This is passed directly to the node.js fs.readFileSync function, so make sure it is formatted as expected."
            ]
          }
        ],
        "execute": [
          "=>",
          [
            "lambda",
            ["input", "options"],
            ["()", "fs", "readFileSync", [".", "input", "path"], "utf8"]
          ]
        ]
      }
    ]
  ],
  [
    "define",
    "add-message-box",
    [
      "lambda",
      ["title", "content"],
      ["()", "message-box", "add", ["LabeledText", "title", "content"]]
    ]
  ],
  [
    "define",
    "render-message-step",
    [
      "lambda",
      ["step"],
      [
        "array/map",
        [".", "step", "content"],
        [
          "lambda",
          ["content"],
          [
            "match",
            "content",
            [],
            ["lambda", ["content"], "Unknown content type"]
          ]
        ]
      ]
    ]
  ],
  ["define", "messages", ["array/make"]],
  ["define", "contents", ["array/make"]],
  [
    "define",
    "on-user-submit",
    [
      "lambda",
      ["message"],
      [
        "begin",
        [
          "define",
          "messages",
          [
            "array/concat",
            "messages",
            ["array/make", { "role": "user", "content": "message" }]
          ]
        ],
        [
          "define",
          "user-message-text",
          [
            "()",
            "OpenTUI",
            "Box",
            {
              "border": true,
              "title": "User"
            },
            ["()", "OpenTUI", "Text", { "content": "message" }]
          ]
        ],
        ["()", "message-box", "add", "user-message-text"],
        [
          "define",
          "handle-response",
          [
            "=>",
            [
              "lambda",
              ["response"],
              [
                "begin",
                [
                  "()",
                  "fs",
                  "writeFileSync",
                  "agent-response-log.json",
                  ["object/json-stringify", "response", null, 2],
                  "utf8"
                ],
                [
                  "array/map",
                  [".", "response", "steps"],
                  [
                    "lambda",
                    ["step"],
                    [
                      "array/map",
                      [".", "step", "content"],
                      [
                        "lambda",
                        ["content"],
                        [
                          "match",
                          "content",
                          [
                            {
                              "type": ["func/partial", "string/equals?", "text"]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Assistant",
                                [".", "c", "text"]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "reasoning"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Reasoning",
                                [".", "c", "text"]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "tool-call"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Tool Call",
                                [
                                  "object/json-stringify",
                                  {
                                    "name": [".", "c", "toolName"],
                                    "input": [".", "c", "input"]
                                  },
                                  null,
                                  2
                                ]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "tool-result"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Tool Result",
                                [".", "c", "output"]
                              ]
                            ]
                          ],
                          [
                            "lambda",
                            ["c"],
                            [
                              "add-message-box",
                              "Error",
                              ["object/json-stringify", "c", null, 2]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ]
            ]
          ]
        ],
        ["console/log", "messages"],
        [
          "()",
          [
            "()",
            "AI",
            "generateText",
            {
              "model": "model",
              "messages": "messages",
              "tools": { "read-file": "file-read-tool" }
            }
          ],
          "then",
          "handle-response"
        ]
      ]
    ]
  ],
  ["()", "my-input", "on", "renderable-events-enter", ["=>", "on-user-submit"]],
  ["()", "OpenTUI", "Box", {}, ["[]", "input-box", "message-box"]]
]
