[
  "begin",
  ["define", "()", "object/call-method"],
  ["define", ".", "object/get-path"],
  ["define", "[]", "array/make"],
  ["define", "=>", "func/callback"],
  ["define", "new", "object/new"],
  [
    "define",
    "message-box",
    [
      "new",
      [".", "OpenTUI", "ScrollBoxRenderable"],
      "renderer",
      {
        "stickyScroll": true,
        "stickyStart": "bottom",
        "width": "100%",
        "height": "100%",
        "border": true,
        "title": "Messages",
        "padding": 1,
        "gap": 4
      }
    ]
  ],
  [
    "define",
    "input-box",
    [
      [".", "OpenTUI", "Box"],
      {
        "border": true
      },
      [
        "define",
        "my-input",
        [
          "new",
          [".", "OpenTUI", "InputRenderable"],
          "renderer",
          {
            "placeholder": "Type your message to Lion Agent here...",
            "width": "full"
          }
        ]
      ]
    ]
  ],
  [
    "define",
    "renderable-events-enter",
    [".", "OpenTUI", "InputRenderableEvents.ENTER"]
  ],
  [
    "define",
    "LabeledText",
    [
      "lambda",
      ["label", "text"],
      [
        "()",
        "OpenTUI",
        "Box",
        {
          "border": true,
          "title": "label"
        },
        ["()", "OpenTUI", "Text", { "content": "text" }]
      ]
    ]
  ],
  [
    "define",
    "file-read-tool",
    [
      "()",
      "AI",
      "tool",
      {
        "description": "Read a file",
        "inputSchema": [
          "()",
          "Zod",
          "object",
          {
            "path": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "Path string to the file to read. This is passed directly to the node.js fs.readFileSync function, so make sure it is formatted as expected."
            ]
          }
        ],
        "execute": [
          "=>",
          [
            "lambda",
            ["input", "options"],
            ["()", "fs", "readFileSync", [".", "input", "path"], "utf8"]
          ]
        ]
      }
    ]
  ],
  [
    "define",
    "read-directory-tool",
    [
      "()",
      "AI",
      "tool",
      {
        "description": "Read a directory",
        "inputSchema": [
          "()",
          "Zod",
          "object",
          {
            "path": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "Path string to the directory to read. This is passed directly to the node.js fs.readdirSync function, so make sure it is formatted as expected."
            ]
          }
        ],
        "execute": [
          "=>",
          [
            "lambda",
            ["input", "options"],
            ["()", "fs", "readdirSync", [".", "input", "path"]]
          ]
        ]
      }
    ]
  ],
  [
    "define",
    "edit-file-tool",
    [
      "()",
      "AI",
      "tool",
      {
        "description": "Edit a file by replacing exactly one matching string",
        "inputSchema": [
          "()",
          "Zod",
          "object",
          {
            "path": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "Path string to the file to edit. This is passed directly to the node.js fs.readFileSync and fs.writeFileSync functions, so make sure it is formatted as expected."
            ],
            "old-string": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "The exact string to replace. It must match exactly one occurrence in the file."
            ],
            "new-string": [
              "()",
              ["()", "Zod", "string"],
              "describe",
              "The replacement string to write in place of old-string."
            ]
          }
        ],
        "execute": [
          "=>",
          [
            "lambda",
            ["input", "options"],
            [
              "begin",
              [
                "define",
                "contents",
                ["()", "fs", "readFileSync", [".", "input", "path"], "utf8"]
              ],
              ["console/log", { "contents": "contents" }],
              [
                "define",
                "parts",
                ["()", "contents", "split", [".", "input", "old-string"]]
              ],
              ["console/log", { "parts": "parts" }],
              [
                "define",
                "match-count",
                ["number/subtract", [".", "parts", "length"], 1]
              ],
              ["console/log", { "match-count": "match-count" }],
              [
                "cond",
                [
                  ["boolean/not", ["number/equals?", "match-count", 1]],
                  [
                    "new",
                    "Error",
                    [
                      "string/concat",
                      "Expected exactly one match for old-string in file, found ",
                      "match-count"
                    ]
                  ]
                ],
                [
                  "else",
                  [
                    "begin",
                    [
                      "define",
                      "updated-contents",
                      [
                        "string/concat",
                        [".", "parts", "0"],
                        [".", "input", "new-string"],
                        [".", "parts", "1"]
                      ]
                    ],
                    [
                      "()",
                      "fs",
                      "writeFileSync",
                      [".", "input", "path"],
                      "updated-contents"
                    ],
                    "updated-contents"
                  ]
                ]
              ]
            ]
          ]
        ]
      }
    ]
  ],
  [
    "define",
    "add-message-box",
    [
      "lambda",
      ["title", "content"],
      ["()", "message-box", "add", ["LabeledText", "title", "content"]]
    ]
  ],
  [
    "define",
    "render-message-step",
    [
      "lambda",
      ["step"],
      [
        "array/map",
        [".", "step", "content"],
        [
          "lambda",
          ["content"],
          [
            "match",
            "content",
            [],
            ["lambda", ["content"], "Unknown content type"]
          ]
        ]
      ]
    ]
  ],
  ["define", "messages", ["[]"]],
  ["define", "contents", ["[]"]],
  [
    "define",
    "on-user-submit",
    [
      "lambda",
      ["message"],
      [
        "begin",
        [
          "define",
          "messages",
          [
            "array/concat",
            "messages",
            ["array/make", { "role": "user", "content": "message" }]
          ]
        ],
        [
          "define",
          "user-message-text",
          [
            "()",
            "OpenTUI",
            "Box",
            {
              "border": true,
              "title": "User"
            },
            ["()", "OpenTUI", "Text", { "content": "message" }]
          ]
        ],
        ["()", "message-box", "add", "user-message-text"],
        ["()", "my-input", "clear"],
        [
          "define",
          "handle-response",
          [
            "=>",
            [
              "lambda",
              ["response"],
              [
                "begin",
                [
                  "define",
                  "messages",
                  [
                    "array/concat",
                    "messages",
                    [".", "response", "response.messages"]
                  ]
                ],
                [
                  "array/map",
                  [".", "response", "steps"],
                  [
                    "lambda",
                    ["step"],
                    [
                      "array/map",
                      [".", "step", "content"],
                      [
                        "lambda",
                        ["content"],
                        [
                          "match",
                          "content",
                          [
                            {
                              "type": ["func/partial", "string/equals?", "text"]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Assistant",
                                [".", "c", "text"]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "reasoning"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Reasoning",
                                [".", "c", "text"]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "tool-call"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Tool Call",
                                [
                                  "object/json-stringify",
                                  {
                                    "name": [".", "c", "toolName"],
                                    "input": [".", "c", "input"]
                                  },
                                  null,
                                  2
                                ]
                              ]
                            ]
                          ],
                          [
                            {
                              "type": [
                                "func/partial",
                                "string/equals?",
                                "tool-result"
                              ]
                            },
                            [
                              "lambda",
                              ["c"],
                              [
                                "add-message-box",
                                "Tool Result",
                                [
                                  "match",
                                  [".", "c", "output"],
                                  ["value/string?", "value/identity"],
                                  [
                                    "value/array?",
                                    [
                                      "lambda",
                                      ["output"],
                                      [
                                        "object/json-stringify",
                                        "output",
                                        null,
                                        2
                                      ]
                                    ]
                                  ],
                                  [
                                    "value/object?",
                                    [
                                      "lambda",
                                      ["output"],
                                      [
                                        "object/json-stringify",
                                        "output",
                                        null,
                                        2
                                      ]
                                    ]
                                  ],
                                  [
                                    "lambda",
                                    ["output"],
                                    ["object/json-stringify", "output", null, 2]
                                  ]
                                ]
                              ]
                            ]
                          ],
                          [
                            "lambda",
                            ["c"],
                            [
                              "add-message-box",
                              "Error",
                              ["object/json-stringify", "c", null, 2]
                            ]
                          ]
                        ]
                      ]
                    ]
                  ]
                ]
              ]
            ]
          ]
        ],
        [
          "()",
          [
            "()",
            "AI",
            "generateText",
            {
              "model": "model",
              "messages": "messages",
              "stopWhen": ["()", "AI", "stepCountIs", 8],
              "tools": {
                "read-file": "file-read-tool",
                "read-directory": "read-directory-tool",
                "edit-file": "edit-file-tool"
              }
            }
          ],
          "then",
          "handle-response"
        ]
      ]
    ]
  ],
  ["()", "my-input", "on", "renderable-events-enter", ["=>", "on-user-submit"]],
  ["()", "OpenTUI", "Box", {}, ["[]", "input-box", "message-box"]]
]
